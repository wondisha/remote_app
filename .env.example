# =============================================================================
# Auto Apply Job - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Primary LLM Configuration (Google Gemini)
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_DELAY=2
GEMINI_RETRY_MAX_DELAY=30

# -----------------------------------------------------------------------------
# Fallback LLM Configuration
# -----------------------------------------------------------------------------
# When Gemini quota is exhausted, fallback to this provider
# Supported: google, openai, anthropic, groq, litellm, ollama
FALLBACK_LLM_PROVIDER=ollama
FALLBACK_LLM_MODEL=qwen2.5:3b

# Fallback API Keys (only needed if provider requires them)
FALLBACK_GOOGLE_API_KEY=
FALLBACK_OPENAI_API_KEY=
FALLBACK_OPENAI_BASE_URL=
FALLBACK_ANTHROPIC_API_KEY=
FALLBACK_GROQ_API_KEY=
FALLBACK_LITELLM_API_KEY=
FALLBACK_LITELLM_BASE_URL=
FALLBACK_OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# Browser Configuration
# -----------------------------------------------------------------------------
# Path to Chrome or Edge executable (auto-detected if not set)
BROWSER_EXECUTABLE_PATH=
# Custom browser profile directory (auto-created if not set)
BROWSER_USER_DATA_DIR=
# Run browser in headless mode (true/false)
BROWSER_HEADLESS=true

# -----------------------------------------------------------------------------
# Ollama Configuration (for local fallback)
# -----------------------------------------------------------------------------
OLLAMA_EXECUTABLE_PATH=
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# Document Generation Settings
# -----------------------------------------------------------------------------
# Model for generating tailored resumes and interview prep
DOCUMENT_LLM_MODEL=qwen2.5:3b
# Character limits to keep local model generation bounded
DOCUMENT_RESUME_CHAR_LIMIT=3500
DOCUMENT_JOB_CHAR_LIMIT=2000
DOCUMENT_MAX_TOKENS=450
# Generate interview prep only (skip tailored resume)
INTERVIEW_PREP_ONLY=false
# Skip document generation entirely during apply
SKIP_DOCUMENT_GENERATION_ON_APPLY=false

# -----------------------------------------------------------------------------
# Candidate Profile
# -----------------------------------------------------------------------------
CANDIDATE_FIRST_NAME=Wondi
CANDIDATE_LAST_NAME=Wolde
CANDIDATE_EMAIL=wondenad@gmail.com
CANDIDATE_PHONE=240-505-7107
CANDIDATE_LINKEDIN_URL=https://linkedin.com/in/wondi
CANDIDATE_GITHUB_URL=https://github.com/wondisha
CANDIDATE_LOCATION=Garland, Texas
# Set to "Yes" if you require visa sponsorship
CANDIDATE_SPONSORSHIP_NEEDED=No

# -----------------------------------------------------------------------------
# Resume Path
# -----------------------------------------------------------------------------
RESUME_PATH=wondi.pdf

# -----------------------------------------------------------------------------
# Job Discovery Settings
# -----------------------------------------------------------------------------
# Portal to search for jobs (linkedin, greenhouse, lever)
JOB_SEARCH_PORTAL=linkedin
# Maximum search results to fetch
JOB_SEARCH_RESULT_LIMIT=25

# Greenhouse company board slugs (comma-separated)
# Example: stripe,notion,airbnb
GREENHOUSE_COMPANY_SLUGS=

# Lever company slugs (comma-separated)
# Example: netflix,figma,sourcegraph
LEVER_COMPANY_SLUGS=

# -----------------------------------------------------------------------------
# Job Ranking Preferences
# -----------------------------------------------------------------------------
# Keywords to prioritize in job titles (comma-separated)
PREFERRED_ROLE_KEYWORDS=snowflake,data engineer,database administrator,data platform,cloud data operations,sql server

# Keywords to prioritize in job locations (comma-separated)
PREFERRED_LOCATION_KEYWORDS=Garland, Texas,Dallas,Texas,Remote,Hybrid

# -----------------------------------------------------------------------------
# Verified Company Policy
# -----------------------------------------------------------------------------
# Require verified company before applying (true/false)
REQUIRE_VERIFIED_COMPANY=true

# Comma-separated list of trusted company names that bypass verification
VERIFIED_COMPANY_ALLOWLIST=

# -----------------------------------------------------------------------------
# Daily Application Target
# -----------------------------------------------------------------------------
DAILY_APPLICATION_TARGET=5

# -----------------------------------------------------------------------------
# Agent Runtime Settings
# -----------------------------------------------------------------------------
# Timeout for LLM responses (seconds)
AGENT_LLM_TIMEOUT=180
# Timeout for agent steps (seconds)
AGENT_STEP_TIMEOUT=240
# Use thinking mode for agent (true/false - requires non-Ollama provider)
AGENT_USE_THINKING=true
# Use vision mode for agent (true/false - not supported by Ollama)
AGENT_USE_VISION=true
# Maximum retry attempts for quota exhaustion
AGENT_MAX_RETRIES=3

# Use fallback LLM as primary (for testing local models)
USE_FALLBACK_AS_PRIMARY=false

# -----------------------------------------------------------------------------
# MSSQL Configuration
# -----------------------------------------------------------------------------
# Option 1: full connection string (overrides all fields below if set)
MSSQL_CONNECTION_STRING=
# Option 2: individual fields
MSSQL_SERVER=localhost
MSSQL_DATABASE=auto_apply
MSSQL_USERNAME=
MSSQL_PASSWORD=
# ODBC driver name (must match what is installed on the machine)
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# -----------------------------------------------------------------------------
# Browser Smoke Test
# -----------------------------------------------------------------------------
# Set to 1 to run browser smoke test only
BROWSER_SMOKE_TEST=0
